# Backend Environment Variables

# Application Configuration
NODE_ENV=development
PORT=3001
API_VERSION=v1
APP_NAME=SecuMint API

# Database Configuration
DATABASE_URL=postgresql://secumint:secumint_dev_password@localhost:5432/secumint_dev
DATABASE_POOL_SIZE=10
DATABASE_SSL=false

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Stacks Blockchain Configuration
STACKS_NETWORK=testnet
STACKS_API_URL=https://stacks-node-api.testnet.stacks.co
STACKS_PRIVATE_KEY=your_stacks_private_key_here
STACKS_CONTRACT_ADDRESS=
STACKS_CONTRACT_NAME=secumint-securities

# SIWS (Sign-In With Stacks) Configuration
SIWS_DOMAIN=localhost:3001
SIWS_URI=http://localhost:3001
SIWS_STATEMENT=Sign in to SecuMint
SIWS_VERSION=1

# File Storage Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=secumint-documents

# Alternative: Supabase Storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# KYC/KYB Service Configuration
# Onfido
ONFIDO_API_TOKEN=
ONFIDO_WEBHOOK_TOKEN=
ONFIDO_REGION=EU

# Alternative: Sumsub
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_BASE_URL=https://api.sumsub.com

# Email Service Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@secumint.com

# Monitoring and Logging
SENTRY_DSN=
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# Security Configuration
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
HELMET_ENABLED=true

# Compliance Configuration
AML_SCREENING_ENABLED=true
KYC_REQUIRED=true
ACCREDITED_INVESTOR_VERIFICATION=true

# Trading Configuration
MTF_API_URL=
MTF_API_KEY=
MTF_WEBHOOK_SECRET=

# Stablecoin Configuration
USDA_CONTRACT_ADDRESS=
USDA_DECIMALS=6

# Oracle Configuration
CHAINLINK_ORACLE_URL=
CHAINLINK_API_KEY=

# Custody Configuration
MPC_PROVIDER=fireblocks
FIREBLOCKS_API_KEY=
FIREBLOCKS_PRIVATE_KEY_PATH=
FIREBLOCKS_BASE_URL=https://api.fireblocks.io

# Development Configuration
DEBUG_MODE=true
MOCK_EXTERNAL_SERVICES=false
SEED_DATABASE=true

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_INTERVAL=30000

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30