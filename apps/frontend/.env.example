# Frontend Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_VERSION=v1

# Stacks Blockchain Configuration
NEXT_PUBLIC_STACKS_NETWORK=testnet
NEXT_PUBLIC_STACKS_API_URL=https://stacks-node-api.testnet.stacks.co
NEXT_PUBLIC_STACKS_EXPLORER_URL=https://explorer.stacks.co

# Wallet Configuration
NEXT_PUBLIC_HIRO_WALLET_URL=https://wallet.hiro.so
NEXT_PUBLIC_CONNECT_WALLET_URL=https://connect.stacks.js.org

# Application Configuration
NEXT_PUBLIC_APP_NAME=SecuMint
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_ENVIRONMENT=development

# Feature Flags
NEXT_PUBLIC_ENABLE_TRADING=true
NEXT_PUBLIC_ENABLE_CUSTODY=true
NEXT_PUBLIC_ENABLE_GOVERNANCE=false
NEXT_PUBLIC_ENABLE_AMM=false

# Analytics and Monitoring
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_SENTRY_DSN=

# External Services
NEXT_PUBLIC_TRADINGVIEW_WIDGET_ID=
NEXT_PUBLIC_CHAINLINK_ORACLE_URL=

# Security
NEXT_PUBLIC_CSP_NONCE=

# Development
NEXT_PUBLIC_DEBUG_MODE=true
NEXT_PUBLIC_MOCK_DATA=false