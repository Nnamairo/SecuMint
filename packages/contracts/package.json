{
  "name": "@secumint/contracts",
  "version": "1.0.0",
  "description": "TypeScript types and utilities for SecuMint Clarity smart contracts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "generate-types": "clarinet run scripts/generate-types.ts",
    "contracts:check": "clarinet check",
    "contracts:test": "clarinet test",
    "contracts:console": "clarinet console"
  },
  "dependencies": {
    "@stacks/transactions": "^6.0.0",
    "@stacks/network": "^6.0.0",
    "@stacks/connect": "^7.0.0",
    "@stacks/clarity": "^6.0.0",
    "@hirosystems/clarinet-sdk": "^2.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist",
    "contracts"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}